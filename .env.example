# RAGFlow Environment Configuration
# Copy this file to .env and fill in your values
# Author: Malav Patel

# ============================================
# LLM Providers (at least one required)
# ============================================
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here  # Required for Claude models
OLLAMA_BASE_URL=http://localhost:11434         # Required for DeepSeek / Llama

# ============================================
# Google AI - Embeddings (REQUIRED)
# Get a free key at: https://aistudio.google.com/apikey
# ============================================
GOOGLE_API_KEY=your_google_ai_studio_key_here

# ============================================
# API Security
# ============================================
# Set a strong random string - all API clients must pass this as X-API-Key header
API_KEY=change_me_to_a_strong_random_secret

# Comma-separated list of allowed CORS origins (use * for dev only)
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# ============================================
# Optional - LangSmith Tracing
# ============================================
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=ragflow

# ============================================
# Celery / Redis
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================
# ChromaDB
# ============================================
# Leave blank for local file persistence (dev)
CHROMA_HOST=
CHROMA_PORT=8000

# ============================================
# RAG Tuning
# ============================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5
